// Copy to Config/Secrets.xcconfig (gitignored). CI materializes the real file
// from GitHub Actions secrets.
//
// Wiring (one-time, in Xcode): Project > Info > Configurations — set
// Config/Secrets.xcconfig as the base configuration for each configuration,
// then replace the hardcoded values in Info.plist with $(VARIABLE_NAME).
// These keys ship inside the app binary regardless — this protects the repo,
// not the runtime.

REVENUECAT_API_KEY = appl_REPLACE_ME
AMPLITUDE_API_KEY = REPLACE_ME
PEXELS_API_KEY = REPLACE_ME
SENTRY_DSN = https:/$()/REPLACE_ME@sentry.io/0
GOOGLE_OAUTH_CLIENT_ID = REPLACE_ME.apps.googleusercontent.com
